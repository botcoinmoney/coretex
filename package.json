{
  "name": "botcoin-cortex",
  "private": true,
  "version": "0.0.0",
  "description": "Botcoin Cortex — on-chain memory codec mining lane",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.5"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "build:bundle": "npm run build --workspace @botcoin/cortex && node scripts/build-coretex-bundle.mjs",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts -vvv",
    "coordinator:epoch-runner": "npm run build --workspace @botcoin/cortex && node scripts/coretex-coordinator-epoch-runner.mjs",
    "coordinator:epoch-runner:e2e": "npm run coretex:epoch-evolve:e2e",
    "coretex:pin-epoch-context": "node scripts/coretex-pin-epoch-context.mjs",
    "coretex:epoch-evolve": "npm run build --workspace @botcoin/cortex && node scripts/coretex-epoch-evolve.mjs",
    "coretex:epoch-evolve:e2e": "npm run build --workspace @botcoin/cortex && node scripts/coretex-epoch-evolve-sync-e2e.mjs",
    "coretex:parity-gate": "npm run build --workspace @botcoin/cortex && node --test packages/cortex/test/unit/reranker-length-bucketing-order.test.mjs packages/cortex/test/unit/qwen-prompt-template-golden.test.mjs packages/cortex/test/unit/reranker-parity-diff-selfcheck.test.mjs packages/cortex/test/unit/validator-runtime.test.mjs",
    "setup:validator": "npm run build --workspace @botcoin/cortex && node scripts/setup-validator-artifacts.mjs",
    "setup:validator:verify": "npm run build --workspace @botcoin/cortex && node scripts/setup-validator-artifacts.mjs --verify-only",
    "validator:replay": "npm run build --workspace @botcoin/cortex && node scripts/coretex-validator.mjs replay-patch",
    "validator:sync": "npm run build --workspace @botcoin/cortex && node packages/cortex/dist/validator-sync-cli.js",
    "validator:verify-launch": "npm run build --workspace @botcoin/cortex && node scripts/coretex-validator.mjs verify-launch"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.6.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.1.0"
  }
}
