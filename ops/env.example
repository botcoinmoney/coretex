# Botcoin Cortex — environment template. Copy to .env and fill.

# ---- Required everywhere ----

# Base mainnet RPC. Must support eth_getLogs for >= 50k blocks.
BASE_RPC_URL=

# Existing SWCP signing key. Reused; never duplicated.
# Lives ONLY on the SWCP coordinator host. cortex-server signs via /internal/sign-cortex-receipt.
COORDINATOR_SIGNING_KEY=

# Already-deployed Botcoin mining contract. Unchanged by Cortex.
BOTCOIN_MINING_V3_ADDRESS=

# ---- Phase 9 (mainnet) ----

CORTEX_REGISTRY_ADDRESS=
CORTEX_MERGE_BONUS_ADDRESS=

# Comma-separated 0x... addresses; audit-window revert signers. 2-of-N required.
MULTISIG_OPERATOR_ADDRESSES=

# ---- Tunables (have defaults) ----

# Audit-and-multisig-override window before merge-bonus funding (§9 Phase 2).
CHALLENGE_WINDOW_SECONDS=21600

# Full-state snapshot cadence (§1). Bounds replay cost.
SNAPSHOT_EPOCH_INTERVAL=100

# Legacy merge multiplier in basis points. 10000 = 1.0x / no separate uplift.
# (Compile-time constant in CortexMergeBonus.sol; setting this env var is
#  informational only — change MERGE_MULTIPLIER_BPS in the contract and
#  redeploy if you want a different value.)
MERGE_MULTIPLIER_BPS=10000

CORTEX_DB_PATH=data/cortex/queue.db
CORTEX_WORKER_POOL_SIZE=

# Production CortexBench eval. Without this (or CORTEX_ALLOW_STUB_EVAL=1 for
# local dev only), cortex-server fails closed rather than issuing stub receipts.
CORTEX_REAL_EVAL=1
# Optional packed 32768-byte current CortexState file. Required after genesis
# unless another process has registered a real evaluator in cortex-server.
CORTEX_STATE_PACKED_PATH=
CORTEX_SCORE_THRESHOLD=0

# Optional elevated-proposal model eval. When enabled, a patch must pass both
# deterministic CortexBench and the local open-weight model retrieval check
# before a receipt is issued. Uses @huggingface/transformers locally.
CORTEX_LOCAL_MODEL_EVAL=1
CORTEX_LOCAL_MODEL=Xenova/multi-qa-MiniLM-L6-cos-v1
CORTEX_LOCAL_MODEL_MIN_DELTA=0
# Pre-embed corpus query/memory texts at first elevated eval. Keeps warm-path
# proposal checks fast. Set 0 only when cold-start time matters more.
CORTEX_LOCAL_MODEL_PREWARM=1
# Optional local model cache and air-gapped mode.
CORTEX_LOCAL_MODEL_CACHE=
CORTEX_LOCAL_MODEL_LOCAL_ONLY=0

# ---- Phase 5 internal RPC (cortex-server <-> SWCP coordinator) ----

INTERNAL_RPC_URL=http://127.0.0.1:8080
INTERNAL_RPC_SHARED_SECRET=
